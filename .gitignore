# Local Database and PHP servers (binary folders)
mariadb/
php/
mailpit/
scratch/

# Playwright MCP debug artifacts (page snapshots, console logs)
.playwright-mcp/

# Environments and Secrets
.env

# SQL Files (Ignore large database dumps but keep project schemas)
import/
*.sql
!sql/civicrm_mock.sql

# Composer files
vendor/
composer.lock
composer.phar


# Windows OS metadata
Thumbs.db
ehthumbs.db
Desktop.ini
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk

# Local Caddy files
caddy.exe
Caddyfile
start-proxy.bat

# Server-side runtime logs
*.log
error_log

# Server-side Basic Auth gates (host-specific paths, e.g. /home/tgg/.htpasswds/...;
# not portable app config -- these protect pre-launch/test deployments)
.htaccess
*.bak

