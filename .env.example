# Application Settings
# IMPORTANT SECURITY WARNING:
# The web server document root MUST be pointed to the public_html/ directory,
# NOT the repository root. Pointing the web server to the root of the project
# will expose sensitive files such as this .env file, database schemas, and source code.
APP_ENV=development
BASE_URL=http://localhost/member
AUTORENEW_LOG_PATH=/var/log/tgg-autorenew.log
# Session directory isolated from other PHP apps on the server (set to /home/tgg/sessions on prod)
SESSION_SAVE_PATH=/tmp

# Local Application Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=tgg_members
DB_USER=root
DB_PASS=

# CiviCRM Database Configuration (on the same MySQL server)
CIVI_DB_HOST=127.0.0.1
CIVI_DB_PORT=3306
CIVI_DB_NAME=wordpress_civicrm
CIVI_DB_USER=root
CIVI_DB_PASS=

# Stripe Credentials
# Use your Stripe test mode keys here
STRIPE_PUBLISHABLE_KEY=pk_test_YourPublishableKeyHere
STRIPE_SECRET_KEY=sk_test_YourSecretKeyHere
STRIPE_WEBHOOK_SECRET=whsec_YourWebhookSecretHere

# One-time Stripe token backfill (bin/backfill-stripe-tokens.php only -- not used anywhere else).
# Set this to a Stripe Restricted Key scoped to READ-ONLY access on Customers and Payment Methods
# (Stripe Dashboard -> Developers -> API keys -> Create restricted key, set Customers and Payment
# Methods to "Read", everything else "None"). Needs LIVE mode data, so this must be a live key
# (rk_live_...), not a test key -- Stripe's test/live customer data is fully separate. Never put
# the full live secret key here.
STRIPE_BACKFILL_SECRET_KEY=

# BoardGameGeek Integration
# BGG_API_TOKEN: application token for the official read-only XML API2 (search/thing/collection).
# BGG requires all XML API2 consumers to register an app at boardgamegeek.com/using_the_xml_api
# and send "Authorization: Bearer <token>" on every request (rolled out July 2025). Register the
# app and generate this token once; used by src/BggClient.php and bin/import-bgg-collection.php.
BGG_API_TOKEN=
# BGG_USERNAME/BGG_PASSWORD authenticate the unofficial, reverse-engineered collection
# write-sync (src/BggCollectionSync.php) -- there is no write API, so this must be the
# real TampaGamingGuild account login. BGG has no scoped API token/app-password mechanism
# for this part -- never logged; sync failure text captured to tgg_games.bgg_last_sync_error
# is scrubbed of credentials before storage.
BGG_USERNAME=TampaGamingGuild
BGG_PASSWORD=

# Mail / SMTP Configuration (defaults to local Mailpit configuration)
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=none
MAIL_FROM_ADDRESS=no-reply@tgg.test
MAIL_FROM_NAME="TGG Membership"

# Geolocation Check Settings for Member Check-Ins
# Set to 'true' to restrict check-ins to the club's physical location.
GEOLOCATION_CHECK_ENABLED=false
# Default coordinates for Tampa Gaming Guild
CLUB_LATITUDE=27.9506
CLUB_LONGITUDE=-82.4572
# Maximum allowed check-in distance in meters (e.g. 150m radius)
CLUB_MAX_CHECKIN_DISTANCE_METERS=150

